    "    )\n",
    "\n",
    "Part_Two_245_NFIP_Shell['Occupy_NFIP'] = np.where(Part_Two_245_NFIP_Shell['SLR'] < Part_Two_245_NFIP_Shell['Year'], 0, 1)\n",
    "\n",
