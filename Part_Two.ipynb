    ")\n",
    "Part_Two_245_NFIP_Shell.loc[mask_4, \"Flood_Occur_4_Factor\"] = 0.961\n",
    "\n",
    "Part_Two_245_NFIP_Shell.loc[Part_Two_245_NFIP_Shell[\"Year\"] == 2025, \"Prox_Flood_1_Factor\"] = 1\n",
