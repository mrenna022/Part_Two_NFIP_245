   "source": [
    "tmp = Part_Two_245_NFIP_Shell[(Part_Two_245_NFIP_Shell['SBL'].astype(str).isin([\"4142431227\", \"3011340029\", \"4142431110\", \"3036180001\", \"3036250007\", \"3086160111\", \"3080580018\", \"3086320028\"]))]"
